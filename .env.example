# =============================================================================
# SaltGoat — Web app environment (SvelteKit / Railway)
# =============================================================================
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# FASTEST REBUILD: if you're logged into the Railway CLI, pull everything at once:
#   railway variables               # list all vars for the linked service
#   railway variables --kv > .env   # dump as KEY=value (review before committing to disk)
#
# Two classes of variable in SvelteKit:
#   PUBLIC_*  -> exposed to the browser, inlined at BUILD time ($env/static/public).
#               These MUST be present when you run `npm run build` or the build fails.
#   others    -> server-only secrets, read at RUNTIME ($env/dynamic/private).
# =============================================================================

# --- Supabase (project: seywnbufuewbiwoouwkk) --------------------------------
# Dashboard: Supabase > Project Settings > API
PUBLIC_SUPABASE_URL=https://seywnbufuewbiwoouwkk.supabase.co   # Project URL (safe to expose)
PUBLIC_SUPABASE_ANON_KEY=                                      # anon / public key (safe to expose)
SUPABASE_SERVICE_ROLE_KEY=                                     # SECRET — full DB access, server-only. Admin client (src/lib/server/supabase.ts) + webhooks. NEVER expose to client.

# --- MapTiler (3D terrain / route maps) --------------------------------------
# Dashboard: maptiler.com > Account > API keys
PUBLIC_MAPTILER_API_KEY=                                       # public map tiles key (domain-restrict it in MapTiler settings)

# --- Stripe (web Pro subscription — currently stubbed) -----------------------
# Dashboard: Stripe > Developers > API keys / Products
STRIPE_SECRET_KEY=                                             # SECRET — sk_test_... or sk_live_...
STRIPE_PRICE_ID=                                              # price_... for SaltGoat Pro ($29.99/yr)
STRIPE_WEBHOOK_SECRET=                                        # whsec_... from the /api/webhooks/stripe endpoint config
# NOTE: PUBLIC_STRIPE_PUBLISHABLE_KEY is NOT referenced in code today. Add it only
#       when you wire up client-side Stripe.js checkout.

# --- RevenueCat (mobile IAP -> web webhook) ----------------------------------
# Dashboard: RevenueCat > Project > Webhooks (Authorization header value)
REVENUECAT_WEBHOOK_SECRET=                                     # SECRET — validates /api/webhooks/revenuecat

# --- Supabase DB webhook (welcome email + newsletter on signup) --------------
# Set as the Bearer token on the Supabase Database Webhook for profiles INSERT
SUPABASE_WEBHOOK_SECRET=                                       # SECRET — validates /api/webhooks/user-signup

# --- Weather pipeline cron ---------------------------------------------------
# Sent as `x-webhook-secret` header by the cron job that hits /api/webhooks/weather
WEBHOOK_SECRET=                                              # SECRET — validates the 4x/daily weather fetch

# --- Sparrow (email gateway: Listmonk + Postmark) ----------------------------
SPARROW_URL=https://sparrow-production-b53e.up.railway.app    # gateway base URL
SPARROW_API_KEY=                                             # SECRET — sent as x-api-key header

# --- Trusted proxy (rate limiting) --------------------------------------------
# adapter-node reads these to resolve the real client IP behind Railway's edge
# proxy for event.getClientAddress() (see src/lib/server/rateLimit.ts). Without
# them, getClientAddress() returns the proxy's own address for every request.
ADDRESS_HEADER=x-forwarded-for                                 # trust XFF for client IP
XFF_DEPTH=1                                                    # 1 trusted proxy hop (Railway edge)

# --- Observability (optional) ------------------------------------------------
# When set, src/lib/server/logger.ts forwards errors to the monitoring seam
# (currently a stub — no SDK installed yet). Leave blank to keep logging as a
# no-op structured console line. See logger.ts for where the Sentry call goes.
# SENTRY_DSN=

# -----------------------------------------------------------------------------
# Analytics (Umami) is hardcoded in src/app.html — no env var required.
# -----------------------------------------------------------------------------
