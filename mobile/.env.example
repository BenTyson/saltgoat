# =============================================================================
# SaltGoat — Mobile app environment (Expo)
# =============================================================================
# Copy to `mobile/.env` and fill in real values. `mobile/.env` is gitignored.
#
# In Expo, EVERY var must be prefixed EXPO_PUBLIC_ to be readable at runtime via
# process.env — which also means they are ALL bundled into the client. Do NOT put
# true secrets here (no service-role key, no Stripe secret). Anon key + public
# API keys only. RevenueCat SDK keys are designed to be public/client-side.
# =============================================================================

# --- Supabase (same project as web: seywnbufuewbiwoouwkk) --------------------
EXPO_PUBLIC_SUPABASE_URL=https://seywnbufuewbiwoouwkk.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=                 # anon / public key (same value as web PUBLIC_SUPABASE_ANON_KEY)

# --- Backend REST API base ---------------------------------------------------
# Dev: your machine's LAN IP + web port (http://localhost:4466 only works in simulator).
# Prod: https://saltgoat.co
EXPO_PUBLIC_API_BASE_URL=https://saltgoat.co

# --- MapTiler (native map) ---------------------------------------------------
EXPO_PUBLIC_MAPTILER_API_KEY=                  # same key as web PUBLIC_MAPTILER_API_KEY

# --- RevenueCat (in-app purchases) -------------------------------------------
# Dashboard: RevenueCat > Project > API keys (public SDK keys, one per platform)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=            # appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=        # goog_...  (only needed once Android app is added)
